# Traveloop Backend - Local Development Configuration

# === Application Settings ===
APP_NAME=Traveloop API
DEBUG=True
VERSION=1.0.0

# === Database Configuration ===
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=traveloop

# === JWT Authentication ===
SECRET_KEY=super_secret_jwt_key_min_32_characters_for_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# === CORS Settings ===
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# === AI Service Configuration ===
AI_PROVIDER=mistral
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=e5cqOp7OoLrsOSTtefMCCJGnLmu6OCfh
MISTRAL_MODEL=mistral-small
MISTRAL_API_URL=https://api.mistral.ai/v1/chat/completions
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # Get from https://huggingface.co/settings/tokens
ENABLE_RAG=False

# === Server Configuration ===
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
RELOAD=True

# === Optional Services ===
CURRENCY_API_KEY=
REDIS_HOST=localhost
REDIS_PORT=6379

# === Logging ===
LOG_LEVEL=INFO
